# MongoDB Database Configuration
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_DB_NAME=scm_project

# JWT Configuration
JWT_SECRET_KEY=generate-a-strong-random-key-here
JWT_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# Application Configuration Defaults
DEFAULT_ROLE=user
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=production
APP_VERSION=0.1.0

# Seed Administrator Account Configurations
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-secure-12-character-password
ADMIN_NAME=System Admin
ADMIN_PHONE=9000000001

# Seed Super Administrator Account Configurations
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-me-to-a-secure-12-character-password
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=9000000002

# Rate Limiting Configurations (Authentication)
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Google reCAPTCHA Login Protection
# Leave blank in local development to use the built-in math CAPTCHA fallback.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
